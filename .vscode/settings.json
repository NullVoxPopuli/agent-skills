{
  "modelContextProtocol": {
    "servers": {
      "ember": {
        "command": "npx",
        "args": ["github:ember-tooling/ember-mcp"],
        "disabled": false
      }
    }
  },
  // ============================================================================
  // Save and formatting behavior
  // ============================================================================
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
